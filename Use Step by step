1 : collect all js file (save js.txt)  
=======================================
2:  mkdir -p js_files
========================================
3. Run this |
             
cat js.txt | while read url; do
  filename=$(echo -n "$url" | md5sum | cut -d' ' -f1)

  curl -s --fail "$url" -o "js_files/$filename.js"

  if [ $? -eq 0 ]; then
    echo "[+] $url -> $filename.js"
  else
    echo "[-] Failed: $url"
  fi
done
